<% issue = @issue || local_assigns[:issue] %>
<% return unless issue %>
<% project = issue.project %>
<% if project.module_enabled?(:external_issue_links) && User.current.allowed_to?(:view_external_issue_links, project) %>
  <% links = issue.external_issue_links.order(:position, :id) %>
  <% can_manage = User.current.allowed_to?(:manage_external_issue_links, project) %>

  <div id="external-issue-links" class="external-issue-links-section" data-sort-url="<%= sort_issue_external_issue_links_path(issue) %>" data-place-before-subtasks="true">
    <h3><%= l(:label_external_issue_links) %></h3>

    <% if can_manage %>
      <p class="external-issue-links-actions">
        <a href="#" class="icon icon-add external-issue-links-toggle-form"><%= l(:label_add_external_issue_link) %></a>
      </p>
    <% end %>

    <% if links.any? %>
      <table class="list external-issue-links-list">
        <thead>
          <tr>
            <% if can_manage %><th class="external-issue-links-drag-column"></th><% end %>
            <th><%= l(:field_source_type) %></th>
            <th><%= l(:field_subject) %></th>
            <th><%= l(:field_url) %></th>
            <% if can_manage %><th class="buttons"></th><% end %>
          </tr>
        </thead>
        <tbody>
          <% links.each do |link| %>
            <tr class="<%= cycle('odd', 'even') %>" data-id="<%= link.id %>">
              <% if can_manage %><td class="external-issue-links-drag-handle" title="<%= l(:label_external_issue_links_drag_hint) %>">⋮⋮</td><% end %>
              <td class="source-name">
                <%= image_tag "source_icons/#{link.source_icon}", plugin: 'redmine_external_issue_links', class: 'external-source-icon', alt: link.source_label, data: { fallback: image_path('source_icons/external.svg', plugin: 'redmine_external_issue_links') } %>
                <%= h(link.source_label) %>
              </td>
              <td class="subject"><%= h(link.subject) %></td>
              <td class="external-url">
                <%= link_to truncate(link.url, length: 80), link.url, target: '_blank', rel: 'noopener' %>
                <button type="button" class="external-issue-links-copy" data-url="<%= h(link.url) %>" title="<%= l(:button_copy_external_issue_link) %>">⧉</button>
              </td>
              <% if can_manage %>
                <td class="buttons">
                  <%= link_to l(:button_delete), external_issue_link_path(link), method: :delete, data: { confirm: l(:text_are_you_sure) }, class: 'icon icon-del' %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <% if can_manage %>
      <fieldset class="external-issue-links-form" style="display:none">
        <legend><%= l(:label_add_external_issue_link) %></legend>
        <%= form_for ExternalIssueLink.new, url: issue_external_issue_links_path(issue) do |f| %>
          <p>
            <%= f.label :source_type, l(:field_source_type) %>
            <%= f.select :source_type, RedmineExternalIssueLinks::SourceRegistry.options, {}, class: 'external-source-select', data: { icon_map: RedmineExternalIssueLinks::SourceRegistry.icon_map.to_json } %>
            <span class="external-source-preview"><%= image_tag 'source_icons/jira.svg', plugin: 'redmine_external_issue_links', class: 'external-source-icon external-source-preview-icon', alt: '' %></span>
          </p>
          <p>
            <%= f.label :subject, l(:field_subject) %>
            <%= f.text_field :subject, size: 60, required: true, class: 'external-subject-input' %>
          </p>
          <p>
            <%= f.label :url, l(:field_url) %>
            <%= f.url_field :url, size: 80, required: true, placeholder: 'https://example.ru/task/123', class: 'external-url-input' %>
            <img class="external-favicon-preview" alt="" style="display:none" />
          </p>
          <p class="buttons">
            <%= f.submit l(:button_add) %>
            <a href="#" class="external-issue-links-cancel"><%= l(:button_cancel) %></a>
          </p>
        <% end %>
      </fieldset>
    <% end %>
  </div>

  <% content_for :header_tags do %>
    <%= stylesheet_link_tag 'external_issue_links', plugin: 'redmine_external_issue_links' %>
    <%= javascript_include_tag 'external_issue_links', plugin: 'redmine_external_issue_links' %>
  <% end %>
<% end %>
